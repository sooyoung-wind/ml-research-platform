# ─── ML Research Platform Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# Loaded by: ml-research CLI, config.py, deepcode_runner.py
# Priority:  project .env  >  ~/.hermes/.env  >  ~/.

# ─── LLM Provider (for code generation) ──────────────────────────────
# One of: openai, anthropic, google, ollama
ML_DEFAULT_LLM_PROVIDER=ollama

# Default model name (provider-specific)
# Examples:
#   ollama:    qwen3:8b, qwen3:4b, glm-5.1:cloud
#   openai:    gpt-4o, o3-mini
#   anthropic: claude-sonnet-4-20250514
#   google:    gemini-2.5-pro
ML_DEFAULT_LLM_MODEL=gemma4:31b-cloud

# ─── Ollama ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=gemma4:31b-cloud

# ─── OpenAI ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ─── Anthropic ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Google / Gemini ─────────────────────────────────────────────────
# GOOGLE_API_KEY=...
# GEMINI_API_KEY=...

# ─── Semantic Scholar ────────────────────────────────────────────────
# SEMANTIC_SCHOLAR_API_KEY=...

# ─── GROBID (optional, PDF parsing) ──────────────────────────────────
# GROBID_BASE_URL=http://localhost:8070

# ─── Notion (optional, reporting) ────────────────────────────────────
# NOTION_API_KEY=...
# NOTION_PARENT_PAGE_ID=...

# ─── GitHub (optional, push generated code) ──────────────────────────
# GITHUB_TOKEN=ghp_...
